# Environment files — NEVER commit secrets
.env
.env.local
.env.production
.env.staging
**/.env
**/.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/
venv/
.venv/
env/

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
mobile/node_modules/
mobile/.expo/
mobile/dist/

# Uploads (user-generated content — not for source control)
backend/uploads/

# Firebase credentials
backend/firebase-credentials.json
**/firebase-credentials.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Alembic
backend/alembic/versions/__pycache__/

# Docker
docker-compose.override.yml

# SSL certificates (generated by nginx/generate-certs.sh — never commit private keys)
nginx/certs/*.pem
nginx/certs/*.key
nginx/certs/*.crt

# Secrets directory — governed by secrets/.gitignore
# (real *.json files are ignored there; *.json.example stays tracked)


# 🚨 HRMS Sensitive Data (VERY IMPORTANT)
*.xlsx
*.xls
*.csv

