# ─── App ────────────────────────────────────────────────────────
APP_NAME=HRMS
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── Database (MySQL) ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hrms_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DATABASE_URL=mysql+aiomysql://root:your_mysql_password@localhost:3306/hrms_db

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_random_32_char_string_minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI / LLM ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6

# ─── Firebase (Push Notifications - Mobile) ─────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─── Object Storage ─────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET_SELFIES=hrms-selfies
S3_BUCKET_DOCUMENTS=hrms-documents

# ─── CORS (comma-separated) ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ─── Timezone ───────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata
